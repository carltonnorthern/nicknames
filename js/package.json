{
  "name": "nicknames-curated",
  "version": "0.1.0",
  "description": "Lookup nicknames and diminutive names for US given names",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickCrews/nicknames",
    "directory": "js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "build": "npm run build:data && tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
